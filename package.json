{
  "name": "Aura",
  "description": "A beautifully crafted, animation-rich personal homepage template. Designed to help you present your projects, blogs, and digital identity — with elegance.",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "prettier --check ."
  },
  "dependencies": {
    "gsap": "^3.12.2",
    "medium-zoom": "^1.0.8",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.0.3",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.3",
    "sass": "^1.32.7",
    "prettier": "^3.4.2"
  },
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "printWidth": 100,
    "proseWrap": "never",
    "tabWidth": 2,
    "bracketSameLine": true,
    "htmlWhitespaceSensitivity": "ignore",
    "vueIndentScriptAndStyle": true
  }
}
